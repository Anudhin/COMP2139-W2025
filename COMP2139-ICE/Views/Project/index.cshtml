@*We expect a list of Projects as its model*@
@model List<Project>

@{
    ViewBag.Title = "Projects";
    Layout = "_Layout";
}

<h2>Projects</h2>

@if (Model.Any())
{
    //Iteration

    <table class="table">

        <thead>
        <th>ID</th>
        <th>Name</th>
        <th>Description</th>
        </thead>

        <tbody>
        @foreach (var project in Model)
        {
            <tr>

                <td>@project.ProjectId</td>
                <td>@project.Name</td>
                <td>@project.Description</td>

            </tr>
        }
        </tbody>

    </table>
}
else
{
    <p>No projects available.</p>
}